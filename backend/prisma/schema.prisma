// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  username      String   @unique
  passwordHash  String
  avatarUrl     String?  
  selectedTitle String?
  
  logs          Log[]
  weeklyReports WeeklyReport[]
  achievements  Achievement[]
  
  friendships   Friendship[]  @relation("UserFriendships")
  friendOf      Friendship[]  @relation("FriendUserships")
  
  friendGroups  FriendGroup[] @relation("UserFriendGroups")
  groupMembers  GroupMember[] @relation("UserGroupMembers")

  expoPushToken String?  // Expo push notification token

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Log {
  id          String   @id @default(uuid())
  receiptId   Int      @default(autoincrement())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  
  date        String   // Stored as YYYY-MM-DD
  title       String?
  location    String?
  
  inputType    String   // "Text" | "Photo" | "Emoji"
  content      String?
  photoUrl     String?

  // Music attachment (iTunes metadata)
  musicTitle   String?
  musicArtist  String?
  musicArtwork String?  // artworkUrl100 from iTunes API

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, date]) // Enforces one log per day per user
  @@index([userId])
  @@index([date])
}

model WeeklyReport {
  id            String   @id @default(uuid())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  
  weekLabel     String   // e.g. "Week 1"
  dateRange     String   // e.g. "Mar 12 ~ Mar 19"
  totalReceipts Int
  subtitle      String?
  
  startDate     DateTime
  endDate       DateTime
  
  createdAt     DateTime @default(now())

  @@unique([userId, startDate])
  @@index([userId])
}

model Achievement {
  id          Int      @id @default(autoincrement())
  userId      String
  titleId     String

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  unlockedAt  DateTime @default(now())

  @@unique([userId, titleId])
}

model Friendship {
  id             Int      @id @default(autoincrement())
  userId         String   
  friendId       String   
  status         String   @default("pending") // "pending" or "accepted"
  notifyOnUpdate Boolean  @default(true)
  createdAt      DateTime @default(now())

  user           User     @relation("UserFriendships", fields: [userId], references: [id], onDelete: Cascade)
  friend         User     @relation("FriendUserships", fields: [friendId], references: [id], onDelete: Cascade)
  
  @@unique([userId, friendId])
  @@index([userId, status])
  @@index([friendId, status])
}

model FriendGroup {
  id        String        @id @default(uuid())
  ownerId   String
  name      String
  owner     User          @relation("UserFriendGroups", fields: [ownerId], references: [id], onDelete: Cascade)
  members   GroupMember[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model GroupMember {
  id        Int         @id @default(autoincrement())
  groupId   String
  userId    String      // the friend added to this group
  group     FriendGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User        @relation("UserGroupMembers", fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([groupId, userId])
}
